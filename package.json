{
  "name": "tabstyr",
  "version": "1.5.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:safari": "wxt build -b safari",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "check:version": "node scripts/sync-readme-version.mjs",
    "version": "node scripts/sync-readme-version.mjs --write && git add .github/badges/version.svg"
  },
  "dependencies": {
    "idb": "^8.0.0",
    "vue": "^3.5.0",
    "vue-i18n": "^10.0.8"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "@wxt-dev/module-vue": "^1.0.0",
    "fake-indexeddb": "^6.0.0",
    "happy-dom": "^20.10.5",
    "sharp": "^0.35.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0",
    "vue-tsc": "^2.2.0",
    "wxt": "^0.20.0"
  }
}
