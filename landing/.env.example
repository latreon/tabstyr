# Landing build-time config. Copy to `.env` and fill in (`.env` is gitignored).
#
# Polar pay-what-you-want checkout link for the support/tip button. Public URL;
# env keeps it out of source. Built locally and uploaded to Netlify, so set this
# before `npm run build`. Leave empty to hide the support links.
VITE_POLAR_CHECKOUT_URL=
