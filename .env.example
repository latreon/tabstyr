# Extension build-time config. Copy to `.env` and fill in (`.env` is gitignored).
#
# Polar pay-what-you-want checkout link for the support button (popup + dashboard).
# Get it from the Polar dashboard → Products → Checkout Links. This is a PUBLIC
# URL (it ships in the built extension); env just keeps it out of source so it's
# swappable per environment. Leave empty to hide the support button.
WXT_POLAR_CHECKOUT_URL=
